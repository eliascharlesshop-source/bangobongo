[
  {
    "name": "theme_info",
    "theme_name": "BangoBongo Music Theme",
    "theme_version": "1.0.0",
    "theme_author": "BangoBongo",
    "theme_documentation_url": "https://github.com/elicharlese/bangobongo",
    "theme_support_url": "https://github.com/elicharlese/bangobongo/issues"
  },
  {
    "name": "Colors",
    "settings": [
      {
        "type": "color",
        "id": "colors_solid_button_labels",
        "default": "#FFFFFF",
        "label": "Solid button label"
      },
      {
        "type": "color",
        "id": "colors_accent_1",
        "default": "#121212",
        "label": "Accent 1"
      },
      {
        "type": "color_background",
        "id": "gradient_accent_1",
        "label": "Accent 1 gradient"
      },
      {
        "type": "color",
        "id": "colors_accent_2",
        "default": "#334FB4",
        "label": "Accent 2"
      },
      {
        "type": "color_background",
        "id": "gradient_accent_2",
        "label": "Accent 2 gradient"
      },
      {
        "type": "color",
        "id": "colors_text",
        "default": "#121212",
        "label": "Text"
      },
      {
        "type": "color",
        "id": "colors_outline_button_labels",
        "default": "#121212",
        "label": "Outline button label"
      },
      {
        "type": "color",
        "id": "colors_background_1",
        "default": "#FFFFFF",
        "label": "Background 1"
      },
      {
        "type": "color_background",
        "id": "gradient_background_1",
        "label": "Background 1 gradient"
      },
      {
        "type": "color",
        "id": "colors_background_2",
        "default": "#F3F3F3",
        "label": "Background 2"
      },
      {
        "type": "color_background",
        "id": "gradient_background_2",
        "label": "Background 2 gradient"
      }
    ]
  },
  {
    "name": "Typography",
    "settings": [
      {
        "type": "font_picker",
        "id": "type_header_font",
        "default": "assistant_n4",
        "label": "Heading font",
        "info": "Selecting a different font can affect the speed of your store. [Learn more about system fonts.](https://help.shopify.com/en/manual/online-store/os/store-speed/improving-speed#fonts)"
      },
      {
        "type": "range",
        "id": "heading_scale",
        "min": 100,
        "max": 150,
        "step": 5,
        "unit": "%",
        "label": "Heading scale",
        "default": 100
      },
      {
        "type": "font_picker",
        "id": "type_body_font",
        "default": "assistant_n4",
        "label": "Body font",
        "info": "Selecting a different font can affect the speed of your store. [Learn more about system fonts.](https://help.shopify.com/en/manual/online-store/os/store-speed/improving-speed#fonts)"
      },
      {
        "type": "range",
        "id": "body_scale",
        "min": 100,
        "max": 130,
        "step": 5,
        "unit": "%",
        "label": "Body scale",
        "default": 100
      }
    ]
  },
  {
    "name": "Layout",
    "settings": [
      {
        "type": "range",
        "id": "page_width",
        "min": 1000,
        "max": 1600,
        "step": 100,
        "default": 1200,
        "unit": "px",
        "label": "Page width"
      },
      {
        "type": "range",
        "id": "spacing_sections",
        "min": 0,
        "max": 100,
        "step": 4,
        "unit": "px",
        "label": "Section spacing",
        "default": 0
      },
      {
        "type": "header",
        "content": "Grid"
      },
      {
        "type": "range",
        "id": "spacing_grid_horizontal",
        "min": 4,
        "max": 40,
        "step": 4,
        "default": 8,
        "unit": "px",
        "label": "Horizontal spacing"
      },
      {
        "type": "range",
        "id": "spacing_grid_vertical",
        "min": 4,
        "max": 40,
        "step": 4,
        "default": 8,
        "unit": "px",
        "label": "Vertical spacing"
      }
    ]
  },
  {
    "name": "Social media",
    "settings": [
      {
        "type": "header",
        "content": "Social accounts"
      },
      {
        "type": "text",
        "id": "social_twitter_link",
        "label": "Twitter",
        "info": "https://twitter.com/shopify"
      },
      {
        "type": "text",
        "id": "social_facebook_link",
        "label": "Facebook",
        "info": "https://facebook.com/shopify"
      },
      {
        "type": "text",
        "id": "social_pinterest_link",
        "label": "Pinterest",
        "info": "https://pinterest.com/shopify"
      },
      {
        "type": "text",
        "id": "social_instagram_link",
        "label": "Instagram",
        "info": "http://instagram.com/shopify"
      },
      {
        "type": "text",
        "id": "social_tiktok_link",
        "label": "TikTok",
        "info": "https://tiktok.com/@shopify"
      },
      {
        "type": "text",
        "id": "social_tumblr_link",
        "label": "Tumblr",
        "info": "https://shopify.tumblr.com"
      },
      {
        "type": "text",
        "id": "social_snapchat_link",
        "label": "Snapchat",
        "info": "https://snapchat.com/add/shopify"
      },
      {
        "type": "text",
        "id": "social_youtube_link",
        "label": "YouTube",
        "info": "https://youtube.com/shopify"
      },
      {
        "type": "text",
        "id": "social_vimeo_link",
        "label": "Vimeo",
        "info": "https://vimeo.com/shopify"
      }
    ]
  },
  {
    "name": "Search",
    "settings": [
      {
        "type": "header",
        "content": "Predictive search"
      },
      {
        "type": "checkbox",
        "id": "predictive_search_enabled",
        "default": true,
        "label": "Enable predictive search"
      },
      {
        "type": "checkbox",
        "id": "predictive_search_show_vendor",
        "default": false,
        "label": "Show vendor",
        "depends_on": "predictive_search_enabled"
      },
      {
        "type": "checkbox",
        "id": "predictive_search_show_price",
        "default": true,
        "label": "Show price",
        "depends_on": "predictive_search_enabled"
      }
    ]
  },
  {
    "name": "Currency",
    "settings": [
      {
        "type": "header",
        "content": "Currency format"
      },
      {
        "type": "checkbox",
        "id": "currency_code_enabled",
        "default": true,
        "label": "Show currency codes"
      }
    ]
  },
  {
    "name": "Cart",
    "settings": [
      {
        "type": "select",
        "id": "cart_type",
        "options": [
          {
            "value": "notification",
            "label": "Notification"
          },
          {
            "value": "page",
            "label": "Page"
          },
          {
            "value": "drawer",
            "label": "Drawer"
          }
        ],
        "default": "notification",
        "label": "Cart type"
      },
      {
        "type": "checkbox",
        "id": "show_vendor",
        "default": false,
        "label": "Show vendor"
      },
      {
        "type": "checkbox",
        "id": "show_cart_note",
        "default": false,
        "label": "Enable cart notes"
      },
      {
        "type": "collection",
        "id": "cart_drawer_collection",
        "label": "Featured collection",
        "info": "Display a featured collection in the cart drawer. Only applies when cart type is set to Drawer."
      }
    ]
  }
]
