# Shopify Configuration
# Copy this to your .env.local file and add your actual Shopify credentials

# Your Shopify store domain (without .myshopify.com)
# Example: if your store is "bangobongo.myshopify.com", enter "bangobongo"
SHOPIFY_DOMAIN=your-shop-name

# Shopify Storefront Access Token
# Create this in your Shopify admin: Settings > Apps and sales channels > Develop apps
# Make sure to enable Storefront API access with these permissions:
# - Read products and their variants
# - Read collections
# - Read product listings
SHOPIFY_STOREFRONT_ACCESS_TOKEN=your_storefront_access_token_here

# Optional: Shopify Admin API (for advanced features)
SHOPIFY_ADMIN_ACCESS_TOKEN=your_admin_access_token_here

# Example values (replace with your actual store):
# SHOPIFY_DOMAIN=bangobongo-music
# SHOPIFY_STOREFRONT_ACCESS_TOKEN=shpat_1234567890abcdef1234567890abcdef
